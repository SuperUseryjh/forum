<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>论坛 · 发帖</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="container">
    <h1>论坛 · 发帖</h1>
    <nav>
        当前用户：<strong><%= q(user.username) %></strong>
        <a href="/forum">看帖</a>
        <a href="/forum/post">发帖</a>
        <a href="/forum/events">事件（<%= unreadCount > 0 ? unreadCount + ' 未查收' : '无' %>）</a>
        <a href="/profile">用户中心</a>
        <a href="/logout">退出登录</a>
    </nav>

    <% if (err === 'empty') { %>
        <div class="alert alert-danger">标题或内容不能为空。</div>
    <% } %>

    <form method="post" action="/api/create_post" class="card">
        <div class="form-group">
            <label>标题</label>
            <input type="text" name="title" placeholder="帖子标题" required>
        </div>
        <div class="form-group">
            <label>内容</label>
            <textarea name="content" rows="8" placeholder="帖子内容..." required></textarea>
        </div>
        <div class="form-actions">
            <button type="submit" name="goto" value="list" class="btn btn-primary">发送并返回列表</button>
            <button type="submit" name="goto" value="post" class="btn">发送并查看帖子</button>
        </div>
    </form>

    <div class="link-actions mt-4">
        <a href="/">返回首页</a>
    </div>
</div>
</body>
</html>