<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>注册</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="container">
    <h1>注册</h1>

    <% if (err === 'empty_username') { %>
        <div class="alert alert-danger">用户名不能为空。</div>
    <% } else if (err === 'invalid_chars') { %>
        <div class="alert alert-danger">用户名不能包含 "_"、"/"、"*"。</div>
    <% } else if (err === 'username_exists') { %>
        <div class="alert alert-danger">用户名已存在。</div>
    <% } else if (err === 'username_length') { %>
        <div class="alert alert-danger">用户名长度需在 2-20 之间。</div>
    <% } else if (err === 'password_too_short') { %>
        <div class="alert alert-danger">密码长度不能少于 4 位。</div>
    <% } %>

    <form method="post" action="/api/register" class="card">
        <div class="form-group">
            <label>用户名</label>
            <input type="text" name="username" placeholder="请输入用户名" required minlength="2" maxlength="20">
        </div>
        <div class="form-group">
            <label>密码</label>
            <input type="password" name="password" placeholder="请输入密码（至少4位）" required minlength="4">
        </div>
        <button type="submit" class="btn btn-primary">注册</button>
    </form>

    <div class="link-actions mt-4">
        <a href="/">返回首页</a>
        <a href="/login">去登录</a>
    </div>
</div>
</body>
</html>